{
  "name": "zenarc-mcp",
  "version": "1.0.0",
  "description": "ZenArc MCP server — AI-native task management for Claude Code via Model Context Protocol",
  "type": "module",
  "bin": {
    "zenarc-mcp": "./dist/server.js",
    "zenarc-migrate": "./dist/core/bin/migrate.js"
  },
  "files": [
    "dist",
    "package.json",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/server.js",
    "migrate": "node dist/core/bin/migrate.js",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "firebase-admin": "^13.0.0",
    "yaml": "^2.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "task-manager",
    "claude",
    "ai",
    "yaml",
    "productivity"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zenarc-dev/zenarc-mcp.git"
  }
}
